###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto

# Declare files that will always have CRLF line endings on checkout.
# map CSVs require CRLF
*.csv text eol=crlf

###############################################################################
# HOI4 / Millennium Dawn file types
###############################################################################

# Game script — UTF-8 without BOM, LF
*.txt   text eol=lf
*.lua   text eol=lf
*.mod   text eol=lf

# Interface files
*.gfx   text eol=lf
*.gui   text eol=lf

# Entity definitions (ASCII text, not binary)
*.asset text eol=lf

# Localisation — UTF-8 with BOM; git normalises line endings but preserves BOM
*.yml   text eol=lf

# Tooling
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf

###############################################################################
# Binary assets — never diff or merge as text
# Both cases listed: Linux fs is case-sensitive so *.dds won't match *.DDS
###############################################################################

# Textures
*.dds   binary
*.DDS   binary
*.tga   binary
*.TGA   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary

# Fonts
*.ttf   binary
*.otf   binary

# Audio
*.mp3   binary
*.ogg   binary
*.wav   binary

# 3D model / animation (Maya/Clausewitz engine formats)
*.mesh   binary
*.anim   binary
*.swatch binary

# Spreadsheets (design/balance docs in resources/)
*.xlsx  binary